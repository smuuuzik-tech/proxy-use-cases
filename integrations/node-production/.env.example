B2B_PROXY_URL=http://proxy.example.net:8080
B2B_PROXY_USERNAME=account-name
B2B_PROXY_PASSWORD=secret-from-secret-manager
B2B_CONNECTION_MODE=pooled
B2B_MAX_ATTEMPTS=3
B2B_CONNECT_TIMEOUT_MS=10000
B2B_HEADERS_TIMEOUT_MS=15000
B2B_BODY_TIMEOUT_MS=30000
B2B_DEADLINE_MS=60000
B2B_MAX_RESPONSE_BYTES=10485760
B2B_BACKOFF_BASE_MS=250
B2B_BACKOFF_MAX_MS=5000
B2B_JITTER_MS=100
B2B_RETRY_AFTER_MAX_MS=10000
B2B_ALLOW_HTTP_TARGETS=false
B2B_ALLOW_PRIVATE_TARGETS=false

# Optional estimate for one network attempt. Configure both values together.
# B2B_ESTIMATED_COST_PER_ATTEMPT=0.002
# B2B_COST_CURRENCY=USD

# Optional authorized rotation diagnostic. Observed values are never printed.
# B2B_ROTATION_TARGET_URL=https://authorized.example.net/identity
# B2B_ROTATION_TARGET_LABEL=authorized identity endpoint
# B2B_ROTATION_JSON_FIELD=ip
# B2B_ROTATION_SAMPLES_PER_MODE=10
