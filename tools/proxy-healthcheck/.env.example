# Required. Keep real credentials in a secret manager or CI secret store.
PHC_PROXY_URL=http://proxy.example.internal:8080
PHC_PROXY_USERNAME=replace_me
PHC_PROXY_PASSWORD=replace_me
PHC_ALLOW_PRIVATE_TARGETS=false

# Either provide endpoints in the config file or override them as JSON here.
# PHC_ENDPOINTS=[{"name":"primary-ip","url":"https://example.com/ip","ip_json_path":"ip","expected_status":[200]}]

PHC_REQUESTS_PER_ENDPOINT=5
PHC_CONCURRENCY=10
PHC_TIMEOUT_SECONDS=5
PHC_RETRY_BUDGET=1
PHC_RETRY_BACKOFF_SECONDS=0.2
PHC_MINIMUM_SUCCESS_RATE=0.95
PHC_FAIL_BELOW_SUCCESS_RATE=0.50
PHC_MAXIMUM_P95_MS=2000
PHC_MINIMUM_UNIQUE_IPS=1
