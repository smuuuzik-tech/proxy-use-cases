# Copy this file to .env and replace only the example proxy address.
# Never commit a real proxy hostname, username, password, or access token.

PROXY_URL=http://proxy.example.com:8080

# Uncomment both lines only when the proxy requires authentication.
# PROXY_USER=replace_me
# PROXY_PASSWORD=replace_me

# The target must use HTTPS. The default returns the public egress IP as JSON.
CHECK_URL=https://api.ipify.org?format=json

# Both values are seconds and may be decimal numbers.
CONNECT_TIMEOUT_SECONDS=10
MAX_TIME_SECONDS=30
