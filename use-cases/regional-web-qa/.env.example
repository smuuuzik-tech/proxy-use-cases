# Copy this file to .env. Never commit .env.
#
# Keep credentials separate from the server URL. Do not use
# http://username:password@proxy.example:3128.
PROXY_SERVER=http://proxy.example:3128
PROXY_USERNAME=replace-me
PROXY_PASSWORD=replace-me

# A business label used only in the evidence filename and report.
REGION_LABEL=de-berlin

# CHECK_URL must use HTTPS on the default port, contain no credentials,
# and match ALLOWED_HOSTS.
CHECK_URL=https://staging.example.com/regional-check
ALLOWED_HOSTS=staging.example.com

# Exact hosts used by scripts, styles, API, images, fonts, and other resources.
# Defaults to ALLOWED_HOSTS when omitted.
RESOURCE_ALLOWED_HOSTS=staging.example.com

# Optional controls.
ARTIFACT_DIR=artifacts
NAVIGATION_TIMEOUT_MS=30000
EXPECTED_STATUS_MIN=200
EXPECTED_STATUS_MAX=399
HEADLESS=true
FULL_PAGE=false
MAX_SCREENSHOT_BYTES=10485760
INCLUDE_PAGE_TITLE=false
ALLOW_PRIVATE_TARGETS=false
