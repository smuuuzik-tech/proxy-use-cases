# Адрес прокси хранится отдельно от учётных данных.
# Не добавляйте username:password@ в URL.
B2B_PROXY_URL=http://proxy.example.net:8080
B2B_PROXY_USERNAME=replace_me
B2B_PROXY_PASSWORD=replace_me

# Раздельные таймауты HTTPX, секунды.
B2B_TIMEOUT_CONNECT_SECONDS=10
B2B_TIMEOUT_READ_SECONDS=30
B2B_TIMEOUT_WRITE_SECONDS=30
B2B_TIMEOUT_POOL_SECONDS=5

# Общее число попыток, включая первую. Допустимо 1..10.
B2B_MAX_ATTEMPTS=3
B2B_BACKOFF_BASE_SECONDS=0.5
B2B_BACKOFF_MAX_SECONDS=8
B2B_BACKOFF_JITTER_SECONDS=0.25
B2B_RETRY_AFTER_MAX_SECONDS=30
B2B_TOTAL_DEADLINE_SECONDS=120
B2B_MAX_RESPONSE_BYTES=1048576

# Пул соединений для параллельных B2B-нагрузок.
B2B_MAX_CONNECTIONS=100
B2B_MAX_KEEPALIVE_CONNECTIONS=20
B2B_FOLLOW_REDIRECTS=false

# Небезопасные значения по умолчанию выключены.
B2B_ALLOW_HTTP_TARGETS=false
B2B_ALLOW_PRIVATE_TARGETS=false

# Опционально: URL и correlation ID без передачи через argv.
# B2B_TARGET_URL=https://service.example/health
# B2B_REQUEST_ID=inventory-sync-0001
