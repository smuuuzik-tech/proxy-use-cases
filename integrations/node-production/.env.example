B2B_PROXY_URL=http://proxy.example.net:8080
B2B_PROXY_USERNAME=account-name
B2B_PROXY_PASSWORD=secret-from-secret-manager
B2B_MAX_ATTEMPTS=3
B2B_CONNECT_TIMEOUT_MS=10000
B2B_HEADERS_TIMEOUT_MS=15000
B2B_BODY_TIMEOUT_MS=30000
B2B_DEADLINE_MS=60000
B2B_MAX_RESPONSE_BYTES=10485760
B2B_BACKOFF_BASE_MS=250
B2B_BACKOFF_MAX_MS=5000
B2B_JITTER_MS=100
B2B_RETRY_AFTER_MAX_MS=10000
B2B_ALLOW_HTTP_TARGETS=false
B2B_ALLOW_PRIVATE_TARGETS=false
