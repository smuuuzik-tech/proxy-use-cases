# Browser route never starts without explicit approval.
B2B_BROWSER_ROUTE_APPROVED=false

# Proxy endpoint and credentials are always separate.
B2B_PROXY_URL=http://proxy.example.net:8080
B2B_PROXY_USERNAME=replace_me
B2B_PROXY_PASSWORD=replace_me

# Approved target and exact host allowlists.
B2B_BROWSER_TARGET_URL=https://service.example/approved-check
B2B_BROWSER_TARGET_LABEL=approved customer check
B2B_BROWSER_ALLOWED_HOSTS=service.example
B2B_BROWSER_RESOURCE_ALLOWED_HOSTS=service.example,static.example

# Bounded execution.
B2B_BROWSER_NAVIGATION_TIMEOUT_MS=30000
B2B_BROWSER_TOTAL_DEADLINE_MS=60000
B2B_BROWSER_MAX_REQUESTS=200
B2B_BROWSER_EXPECTED_STATUS_MIN=200
B2B_BROWSER_EXPECTED_STATUS_MAX=399
B2B_BROWSER_HEADLESS=true
B2B_BROWSER_ALLOW_PRIVATE_TARGETS=false

# Sensitive evidence is opt-in and remains local.
B2B_BROWSER_CAPTURE_SCREENSHOT=false
B2B_BROWSER_CAPTURE_TRACE=false
B2B_BROWSER_FULL_PAGE=false
B2B_BROWSER_MAX_SCREENSHOT_BYTES=10485760
B2B_BROWSER_ARTIFACT_DIR=.browser-jobs
