{
  "name": "andrey-proxy-sdk-node",
  "version": "0.4.0",
  "description": "Provider-neutral Node.js proxy SDK with bounded HTTP requests, explicit connection strategies, safe rotation diagnostics, and an optional policy-gated browser route.",
  "type": "module",
  "main": "./src/client.js",
  "types": "./src/client.d.ts",
  "exports": {
    ".": {
      "types": "./src/client.d.ts",
      "import": "./src/client.js"
    },
    "./browser": {
      "types": "./src/browser.d.ts",
      "import": "./src/browser.js"
    },
    "./rotation": {
      "types": "./src/rotation.d.ts",
      "import": "./src/rotation.js"
    }
  },
  "bin": {
    "andrey-proxy-node": "./src/cli.js",
    "andrey-proxy-browser": "./src/browser-cli.js",
    "andrey-proxy-rotation": "./src/rotation-cli.js"
  },
  "files": [
    "src",
    "scripts",
    "README.md",
    ".env.example",
    ".env.browser.example",
    "acceptance.example.json"
  ],
  "scripts": {
    "check": "node --check src/client.js && node --check src/execution.js && node --check src/job-store.js && node --check src/browser.js && node --check src/acceptance.js && node --check src/browser-cli.js && node --check src/rotation.js && node --check src/rotation-cli.js && node --check scripts/local-acceptance.mjs && node --check src/cli.js",
    "test": "node --test",
    "smoke:cli": "node src/browser-cli.js --help && node src/rotation-cli.js --help && node scripts/local-acceptance.mjs --help",
    "acceptance:local": "node scripts/local-acceptance.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "undici": "7.28.0"
  },
  "peerDependencies": {
    "playwright": ">=1.61.0 <2"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "keywords": [
    "proxy",
    "http",
    "https",
    "connection-strategy",
    "rotation-diagnostic",
    "undici",
    "playwright",
    "browser",
    "durable-jobs",
    "replay",
    "b2b",
    "sdk"
  ],
  "author": "Andrey Malyshev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smuuuzik-tech/proxy-use-cases.git",
    "directory": "integrations/node-production"
  },
  "homepage": "https://github.com/smuuuzik-tech/proxy-use-cases/tree/main/integrations/node-production",
  "bugs": {
    "url": "https://github.com/smuuuzik-tech/proxy-use-cases/issues"
  }
}
