{
  "name": "andrey-proxy-sdk-node",
  "version": "0.1.0",
  "description": "Provider-neutral Node.js proxy client with bounded retries, timeouts, response limits, and redacted results.",
  "type": "module",
  "main": "./src/client.js",
  "types": "./src/client.d.ts",
  "exports": {
    ".": {
      "types": "./src/client.d.ts",
      "import": "./src/client.js"
    }
  },
  "bin": {
    "andrey-proxy-node": "./src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "check": "node --check src/client.js && node --check src/cli.js",
    "test": "node --test",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "undici": "7.28.0"
  },
  "keywords": [
    "proxy",
    "http",
    "https",
    "undici",
    "b2b",
    "sdk"
  ],
  "author": "Andrey Malyshev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smuuuzik-tech/proxy-use-cases.git",
    "directory": "integrations/node-production"
  },
  "homepage": "https://github.com/smuuuzik-tech/proxy-use-cases/tree/main/integrations/node-production",
  "bugs": {
    "url": "https://github.com/smuuuzik-tech/proxy-use-cases/issues"
  }
}
